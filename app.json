{
  "expo": {
    "name": "RG Medlink",
    "slug": "rg-medlink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.rgmedlink.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D0810"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow RG Medlink to use your location to find nearby pharmacies and deliver to your address.",
          "locationWhenInUsePermission": "Allow RG Medlink to use your location to find nearby pharmacies and deliver to your address."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow RG Medlink to access your camera to photograph prescriptions.",
          "photosPermission": "Allow RG Medlink to access your photos to upload prescriptions."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9dfee68a-65a0-4ab9-b0de-04ca8716b189"
      }
    },
    "owner": "nnc1"
  }
}
